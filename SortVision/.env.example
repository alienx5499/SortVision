# ===========================================
# SortVision Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control!

# ===========================================
# GitHub API Configuration
# ===========================================
# Get your token from: https://github.com/settings/personal-access-tokens/tokens
# Required scopes: public_repo (for public repositories)
NEXT_PUBLIC_GITHUB_TOKEN=your_github_token_here

# Main Repository Configuration (for stars, contributors, etc.)
NEXT_PUBLIC_GITHUB_REPO_OWNER=your_username
NEXT_PUBLIC_GITHUB_REPO_NAME=your_repo_name

# Feedback Repository Configuration (for bug reports, suggestions)
NEXT_PUBLIC_FEEDBACK_REPO_OWNER=your_feedback_username
NEXT_PUBLIC_FEEDBACK_REPO_NAME=your_feedback_repo_name

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://api.github.com
NEXT_PUBLIC_API_USER_AGENT=SortVision-App

# ===========================================
# Development Configuration
# ===========================================
# Set to true for development mode features (set to false in production)
NEXT_PUBLIC_DEV_MODE=true

# Enable API request logging (useful for debugging, set to false in production)
NEXT_PUBLIC_ENABLE_API_LOGGING=true

# ===========================================
# Chatbot Configuration
# ===========================================
# Chat provider: local (free) or nvidia (remote)
NEXT_PUBLIC_CHAT_PROVIDER=local

# NVIDIA OpenAI-compatible API key (required only for remote AI mode)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=moonshotai/kimi-k2-instruct
NVIDIA_MODEL_FALLBACKS=
NVIDIA_TIMEOUT_MS=7000
NVIDIA_TEMPERATURE=0.6
NVIDIA_TOP_P=0.9
NVIDIA_MAX_TOKENS=512

# Chat moderation and CORS controls
NEXT_PUBLIC_CHAT_ABUSE_THRESHOLD=3
CHAT_ABUSE_THRESHOLD=3
CHAT_ABUSE_WINDOW_MS=600000
CHAT_ABUSE_BLOCK_MS=86400000
CHAT_ABUSE_TRACKER_MAX_SIZE=5000
CORS_ALLOWED_ORIGINS=