{
  "name": "sort-vision",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "test": "node tests/qa/quality-assurance.ts",
    "test:ci": "node tests/qa/quality-assurance.ts --extended",
    "test:unit": "vitest run",
    "test:quick": "node tests/qa/quality-assurance.ts --quick",
    "test:prod": "node tests/qa/quality-assurance.ts --production",
    "test:extended": "node tests/qa/quality-assurance.ts --extended",
    "dev": "next dev --turbopack",
    "build": "next build",
    "check:push": "pnpm run format:check && pnpm run lint && pnpm run build",
    "tsc": "tsc --noEmit",
    "chat-server": "node server/index.ts",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "preview": "next start",
    "generate-og": "node scripts/generate-og-image.js",
    "generate-sitemap": "echo \"Dynamic sitemap enabled at /sitemap.xml (no static generation needed)\"",
    "submit-indexnow": "node scripts/submit-indexnow.mjs --sitemap",
    "test-sitemap": "node scripts/test-sitemap-urls.js",
    "test-sitemap-bash": "bash scripts/test-sitemap-urls.sh",
    "validate-seo": "npm run test-sitemap && npm run submit-indexnow",
    "clean": "rm -rf .next node_modules/.cache",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@surma/rollup-plugin-off-main-thread": "^2.2.3",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bad-words": "^4.1.5",
    "braces": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dompurify": "^3.4.12",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "filelist": "^2.0.2",
    "framer-motion": "^12.42.2",
    "http-proxy-middleware": "^4.2.0",
    "jake": "^12.10.1",
    "lucide-react": "^1.24.0",
    "micromatch": "^4.0.8",
    "minimatch": "^10.2.5",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.10",
    "node-fetch": "^3.3.2",
    "node-html-parser": "^9.0.0",
    "on-headers": "^1.1.0",
    "openai": "^6.47.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-ga4": "^3.0.1",
    "react-helmet": "^6.1.0",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/plugin-kit": "^0.7.2",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.43",
    "compression": "^1.8.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "express": "^5.2.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "react-doctor": "^0.8.1",
    "typescript-eslint": "^8.64.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10",
    "wait-on": "9.0.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.12",
      "dompurify": "^3.4.11",
      "brace-expansion": "^5.0.6",
      "ws": "^8.20.1"
    },
    "ignoredBuiltDependencies": [
      "@vercel/speed-insights",
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
      }
    }
  },
  "knip": {
    "ignore": [
      "public/**"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,json,css,md,yml,yaml}": [
      "git add"
    ]
  },
  "packageManager": "pnpm@11.13.0"
}
